@{
    ViewData["Title"] = "Acerca de Nosotros";
    var sistemaNombre = "Sistema de Programación Web Avanzada";
    var fechaSistema = DateTime.Now;
}

<div class="card shadow-lg rounded-3 mb-4">
    <div class="card-body p-4">
        <div class="alert alert-info d-flex justify-content-between align-items-center mb-4">
            <div>
                <strong>Sistema:</strong> @sistemaNombre
            </div>
            <div>
                <strong>Fecha:</strong> @fechaSistema.ToString("dd/MM/yyyy HH:mm:ss")
            </div>
        </div>

        

        <h2 class="text-primary mb-4 pb-2 border-bottom border-3 border-secondary">Nuestro Equipo</h2>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mt-2">

            <h2 class="display-4">Felipe Quesada Herrera</h2>
            <h2 class="display-4">Ian Aguilar Brenes</h2>
            <h2 class="display-4">Sebastian Mendes Artavia</h2>
            <h2 class="display-4">Jason Orozco Ruiz</h2>



        </div>
    </div>
</div>