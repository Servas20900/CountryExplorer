@model CountryDto?
@{
    ViewData["Title"] = "Busqueda de pais";
}

<div class="space-y-8">
    @if (Model is null)
    {
        <div class="rounded-3xl border border-dashed border-slate-300 bg-white p-10 text-center text-slate-600">
            No se encontro ningun pais.
        </div>
    }
    else
    {
        <section class="grid gap-6 lg:grid-cols-2">
            <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg shadow-slate-200/60">
                <img src="@Model.FlagPngUrl" alt="@Model.CommonName flag" class="h-40 w-full rounded-2xl object-contain bg-slate-50 p-4" />
                <h2 class="mt-5 text-3xl font-black text-slate-950">@Model.CommonName</h2>
                <p class="mt-2 text-sm text-slate-600">@Model.OfficialName</p>
            </article>

            <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-lg shadow-slate-200/60">
                <div class="space-y-4 text-sm text-slate-700">
                    <div><span class="font-semibold text-slate-900">Capital:</span> @Model.Capital</div>
                    <div><span class="font-semibold text-slate-900">Region:</span> @Model.Region</div>
                    <div><span class="font-semibold text-slate-900">Subregion:</span> @Model.Subregion</div>
                    <div><span class="font-semibold text-slate-900">Codigo:</span> @Model.CountryCode</div>
                </div>
            </article>
        </section>

        <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-lg shadow-slate-200/60">
            <div id="map" class="h-[420px] w-full"></div>
        </section>

        <div class="flex flex-wrap justify-end gap-3">
            <button id="saveCountryButton" type="button" class="rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-indigo-500">
                Guardar pais
            </button>
        </div>

    }
</div>

@section Scripts {
    @if (Model is not null)
    {
        <script>
            const countryCode = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CountryCode));
            const commonName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CommonName));
            const flagPngUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FlagPngUrl));
            const capital = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Capital));
            const map = L.map('map').setView([@Model.Latitude, @Model.Longitude], 5);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);
            L.marker([@Model.Latitude, @Model.Longitude]).addTo(map).bindPopup(capital).openPopup();

            document.getElementById('saveCountryButton').addEventListener('click', async () => {
                const response = await fetch(`${window.explorerApiBaseUrl}api/countries/save`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        countryCode,
                        commonName,
                        officialName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OfficialName)),
                        capital,
                        region: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Region)),
                        subregion: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Subregion)),
                        flagPngUrl,
                        flagSvgUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FlagSvgUrl)),
                        latitude: @Model.Latitude,
                        longitude: @Model.Longitude
                    })
                });

                if (!response.ok) {
                    window.showAppBanner('No se pudo guardar el pais.', 'error');
                    return;
                }

                const payload = await response.json();
                window.showAppBanner(payload.mensaje, payload.guardado ? 'success' : 'warning');
            });
        </script>
    }
}
