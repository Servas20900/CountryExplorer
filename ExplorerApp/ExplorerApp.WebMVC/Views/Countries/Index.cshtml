@{
    ViewData["Title"] = "Explorador";
}

<div class="flex min-h-[70vh] items-center justify-center">
    <div class="w-full max-w-2xl rounded-3xl border border-slate-200 bg-white p-8 shadow-xl shadow-slate-200/60">
        <div class="mb-6 text-center">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-slate-500">REST COUNTRIES</p>
            <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">Buscar un pais</h1>
            <p class="mt-3 text-sm leading-6 text-slate-600">Consulta un pais y revisa su informacion, mapa y flujo de guardado.</p>
        </div>

        <form id="searchForm" asp-controller="Countries" asp-action="Search" method="get" class="flex gap-3">
            <input type="text" name="query" placeholder="Escribe el nombre de un pais" class="flex-1 rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-slate-950" />
            <button id="searchButton" type="submit" class="rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-700">Buscar</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchButton').addEventListener('click', () => {
            window.showAppBanner('Buscando pais...', 'success');
        });
    </script>
}
