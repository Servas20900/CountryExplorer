@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExplorerApp.WebMVC</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.css" referrerpolicy="no-referrer" />
</head>
<body>
    <script>
        window.explorerApiBaseUrl = '@(Configuration["ApiSettings:ExplorerApiBaseUrl"] ?? "http://localhost:5081/")';
        window.showAppBanner = function (message, type) {
            const banner = document.getElementById('appBanner');
            const text = document.getElementById('appBannerText');

            banner.classList.remove('hidden', 'bg-emerald-600', 'bg-rose-600', 'bg-amber-600');
            banner.classList.add(type === 'success' ? 'bg-emerald-600' : type === 'warning' ? 'bg-amber-600' : 'bg-rose-600');
            text.textContent = message;

            window.clearTimeout(window.__appBannerTimer);
            window.__appBannerTimer = window.setTimeout(() => {
                banner.classList.add('hidden');
            }, 2500);
        }
    </script>
    <div id="appBanner" class="fixed right-4 top-4 z-50 hidden rounded-xl px-4 py-3 text-sm font-semibold text-white shadow-lg">
        <span id="appBannerText"></span>
    </div>
    <header class="border-b border-slate-200 bg-white/90 backdrop-blur">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
            <a class="text-lg font-semibold text-slate-900" asp-controller="Countries" asp-action="Index">ExplorerApp</a>
            <nav class="flex items-center gap-4 text-sm font-medium text-slate-700">
                <a asp-controller="Countries" asp-action="Index" class="hover:text-slate-950">Inicio</a>
                <a asp-controller="Countries" asp-action="Saved" class="hover:text-slate-950">Paises guardados</a>
                <a asp-controller="Countries" asp-action="Archived" class="hover:text-slate-950">Archivados</a>
            </nav>
        </div>
    </header>
    <main class="mx-auto min-h-[calc(100vh-73px)] max-w-6xl px-6 py-10">
        @RenderBody()
    </main>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.js" referrerpolicy="no-referrer"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
